{
  "manifest_version": 3,
  "name": "Focus Guard — Block Reels & Shorts",
  "version": "1.1.2",
  "description": "Block YouTube Shorts, Facebook Reels, and other distractions. AI-powered content filtering with Gemini.",
  "permissions": ["storage", "declarativeNetRequest", "activeTab"],
  "host_permissions": [
    "https://www.youtube.com/*",
    "https://www.facebook.com/*",
    "https://m.facebook.com/*",
    "https://www.tiktok.com/*",
    "https://www.instagram.com/*",
    "https://generativelanguage.googleapis.com/*"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": "icons/icon48.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.youtube.com/*",
        "https://www.facebook.com/*",
        "https://m.facebook.com/*",
        "https://www.tiktok.com/*",
        "https://www.instagram.com/reels/*"
      ],
      "css": ["content/blocker.css"],
      "js": ["content/blocker.js"],
      "run_at": "document_start"
    }
  ],
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "block_rules",
        "enabled": true,
        "path": "rules.json"
      }
    ]
  }
}
